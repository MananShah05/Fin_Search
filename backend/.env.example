# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./service-account.json
FIREBASE_PROJECT_ID=your-project-id

# Firebase Client SDK (for token verification)
FIREBASE_API_KEY=your-api-key

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=finsearch_chunks

# Storage config (local or gcs)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/pdfs
GCS_BUCKET=finsearch-pdfs

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=info

# API
API_PREFIX=/api/v1

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking & Search tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=64
DENSE_TOP_K=50
SPARSE_TOP_K=50
RRF_ALPHA=0.6
FINAL_TOP_K=10